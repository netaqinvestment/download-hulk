{
  "manifest_version": 3,
  "name": "Download Hulk",
  "version": "1.0.0",
  "description": "Send any video to Download Hulk for fast downloading",
  "permissions": ["activeTab", "contextMenus"],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon48.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.instagram.com/*",
        "*://*.facebook.com/*",
        "*://*.tiktok.com/*",
        "*://*.twitter.com/*",
        "*://*.x.com/*",
        "*://*.reddit.com/*",
        "*://*.vimeo.com/*",
        "*://*.twitch.tv/*",
        "*://*.dailymotion.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
